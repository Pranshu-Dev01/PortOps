# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to git

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Base URL for the OpenAI-compatible endpoint (leave blank for official OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1       # default — official OpenAI
# OPENAI_BASE_URL=http://localhost:11434/v1        # Ollama (local)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1    # OpenRouter
# OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/  # Azure OpenAI

# ─── Hugging Face ─────────────────────────────────────────────
HF_TOKEN=hf_...
HF_USERNAME=your-hf-username

# ─── PortOps Server (optional overrides) ──────────────────────
PORTOPS_BASE_URL=http://localhost:7860
PORTOPS_MODEL=gpt-4o-mini
